# Puddle — environment variables
# Copy to .env and fill in values.

# RainbowKit / WalletConnect project ID (get one at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Deployed RibbonPuddle contract address on Base (set after running: npm run deploy:base)
VITE_PUDDLE_CONTRACT_ADDRESS=

# Pinata JWT for IPFS metadata pinning (optional — minting works without it)
VITE_PINATA_JWT=

# Deployer private key — ONLY used by deploy script, never bundled into frontend
DEPLOYER_PRIVATE_KEY=
